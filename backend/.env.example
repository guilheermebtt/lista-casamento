# Access Token (Credenciais de teste OU produção — o mesmo usado para PIX e cartão). Sem aspas; reinicie a API após editar.
# https://www.mercadopago.com.br/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Painel admin no site (rodapé → Painel admin ou URL #admin). Use uma frase longa e secreta.
ADMIN_SECRET=uma-frase-secreta-longa

# Porta do servidor (opcional)
PORT=3001

# URL pública do backend (webhook). Use sempre https:// (http:// gera erro no MP ao criar PIX).
# PUBLIC_URL=https://seu-backend.railway.app

# Segredo opcional para validar webhooks (Mercado Pago envia assinatura em x-signature)
# WEBHOOK_SECRET=
