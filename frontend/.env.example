# URL pública da API em produção (ex: https://sua-api.railway.app)
# Em desenvolvimento deixe vazio — o Vite faz proxy para localhost:3001 (presentes vêm de GET /api/gifts)
VITE_API_URL=

# Chave PÚBLICA do Mercado Pago (coluna "Public key" / credenciais de teste ou produção).
# NÃO cole aqui o Access Token — é só para o backend e quebra o Brick (404 / erro de site ID no console).
# Painel: https://www.mercadopago.com.br/developers/panel/credentials
VITE_MERCADOPAGO_PUBLIC_KEY=
